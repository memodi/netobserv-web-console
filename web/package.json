    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-code-editor": "^6.4.2",
    "@patternfly/react-core": "^6.4.2",
    "@patternfly/react-drag-drop": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/react-table": "^6.4.2",
    "@patternfly/react-tokens": "^6.4.0",
    "@patternfly/react-topology": "^6.4.0",
    "@rjsf/core": "^5.24.12",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.12",
    "@types/classnames": "^2.3.0",
    "axios": "^1.16.0",
    "classnames": "^2.5.1",
    "i18next": "~25.6.2",
    "i18next-http-backend": "^4.0.0",
    "js-yaml": "^4.2.0",
    "murmurhash-js": "^1.0.0",
    "percentile": "^1.6.0",
    "port-numbers": "^6.0.1",
    "protocol-numbers": "^0.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "~16.5.8",
    "react-icons": "^5.5.0",
    "react-router": "~7.13.1",
    "victory": "^37.3.6"
  },
  "overrides": {
    "glob-parent": "^6.0.1"
  }
}
