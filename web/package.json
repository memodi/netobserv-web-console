{
  "name": "netobserv-plugin",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf ./dist",
    "clean:static": "rm -rf ./dist/static",
    "build": "npm run clean && NODE_ENV=production npm run ts-node ./node_modules/.bin/webpack",
    "build:static": "npm run clean:static && FLAVOR=static NODE_ENV=production npm run ts-node ./node_modules/.bin/webpack",
    "build:dev": "npm run clean && npm run ts-node ./node_modules/.bin/webpack",
    "build:standalone": "npm run clean && webpack --config webpack.standalone.js",
    "start": "npm run ts-node-transpile ./node_modules/.bin/webpack serve",
    "start:standalone": "webpack serve --config webpack.standalone.js",
    "serve": "npx http-server ./dist -p 9001 -c-1 --cors $SERVER_OPTS",
    "i18n": "i18next \"src/**/*.{js,jsx,ts,tsx}\" [-oc] -c i18next-parser.config.js",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "ts-node-transpile": "ts-node --transpile-only -O '{\"module\":\"commonjs\"}' -I '/node_modules/(?!(@openshift-console)/)/'",
    "cypress:open": "cypress open",
    "cypress:record": "cypress run --spec \"cypress/e2e/**/*.spec.ts\" --record --headless",
    "cypress:run": "cypress run --spec \"cypress/e2e/**/*.spec.ts\"",
    "test": "jest",
    "test:clear": "jest --clearCache && npm run test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --colors",
    "lint": "./node_modules/.bin/eslint \"./src/**/*.{ts,tsx}\"",
    "format": "pretty-quick --branch main",
    "format-all": "prettier --write \"./src/**/*.{ts,tsx}\" && npm run fix-imports",
    "fix-imports": "eslint --no-eslintrc --no-inline-config --parser '@typescript-eslint/parser' --plugin 'unused-imports' --plugin 'react-hooks' --rule 'unused-imports/no-unused-imports:error' --fix \"./src/**/*.{ts,tsx}\"",
    "clean:cache": "rm -rf node_modules/.cache",
    "clean:all": "npm run clean && npm run clean:cache"
  },
  "devDependencies": {
    "ajv": "^8.17.0",
    "@babel/core": "^7.29.6",
    "@babel/plugin-transform-typescript": "^7.17.12",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@cypress/grep": "^4.1.1",
    "@openshift-console/dynamic-plugin-sdk": "4.22.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.22.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/copy-webpack-plugin": "8.0.1",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^16.2.13",
    "@types/lodash": "^4.17.20",
    "@types/murmurhash-js": "^1.0.3",
    "@types/port-numbers": "^5.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-transition-group": "^4.4.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "babel-loader": "^10.0.0",
    "babel-preset-react": "^6.24.1",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "^7.1.4",
    "cypress": "15.16.0",
    "cypress-multi-reporters": "^2.0.5",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-webpack-plugin": "^5.5.0",
    "http-server": "^14.1.1",
    "i18next-parser": "^9.3.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jsdom": "28.1.0",
    "jsdom-global": "3.0.2",
    "mini-css-extract-plugin": "^2.10.0",
    "mobx": "^6.9.0",
    "mocha-junit-reporter": "^2.2.1",
    "parse-duration": "^1.1.0",
    "prettier": "^2.5.1",
    "prettier-plugin-organize-imports": "^3.2.4",
    "pretty-quick": "^3.1.2",
    "react-transition-group": "^4.4.2",
    "style-loader": "^3.3.1",
    "ts-jest": "29.4.5",
    "ts-jest-resolver": "2.0.1",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.5",
    "webpack-node-externals": "3.0.0"
  },
  "consolePlugin": {
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "@jpinsonneau/html-to-image": "^1.11.13",
